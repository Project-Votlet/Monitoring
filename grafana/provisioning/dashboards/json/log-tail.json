          { "text": "Auth",         "value": "auth-service",        "selected": false },
          { "text": "Profile",      "value": "profile-service",     "selected": false },
          { "text": "Social",       "value": "social-service",      "selected": false },
          { "text": "Message",      "value": "message-service",     "selected": false },
          { "text": "Notification", "value": "notification-service","selected": false },
          { "text": "Space",        "value": "space-service",       "selected": false },
          { "text": "Voice",        "value": "voice-service",       "selected": false },
          { "text": "Webhook",      "value": "webhook-service",     "selected": false },
          { "text": "Bot",          "value": "bot-service",         "selected": false },
          { "text": "Admin",        "value": "admin-service",       "selected": false },
          { "text": "Media",        "value": "media-service",       "selected": false },
          { "text": "Reverb",       "value": "reverb",              "selected": false },
          { "text": "Nginx",        "value": "nginx",               "selected": false },
          { "text": "Postgres",     "value": "postgres",            "selected": false },
          { "text": "Redis",        "value": "redis",               "selected": false },
          { "text": "NATS",         "value": "nats",                "selected": false }
